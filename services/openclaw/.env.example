# ─────────────────────────────────────────────────────────────
# OpenClaw Gateway
# Container: openclaw-gateway
# ─────────────────────────────────────────────────────────────

# Telegram Bot Token — create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID.
# Use @userinfobot in Telegram to find yours.
# OpenClaw restricts commands to this user only.
TELEGRAM_USER_ID=
