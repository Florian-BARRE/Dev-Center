# syntax=docker/dockerfile:1.7

###############################################################################
# Build note:
# Built from repository root with src/ as the build context.
# Example:
#   docker build -f src/dev_center_app/frontend/Dockerfile.dev -t dev-center-frontend:dev src
###############################################################################

###############################################################################
# Stage 1: Frontend development runtime (Node + Vite)
#
# Goal:
# - Provide a reproducible frontend dev environment
# - Pre-install node_modules so startup is fast and deterministic
###############################################################################
FROM node:22-bookworm-slim AS frontend-dev

# Work inside the frontend source tree.
WORKDIR /workspace/frontend

# Copy dependency manifests first for better Docker layer caching.
COPY dev_center_app/frontend/package.json dev_center_app/frontend/package-lock.json ./

# Install exact dependencies from package-lock.json.
RUN npm ci

# Expose Vite development port.
EXPOSE 5173

# Start Vite in container-friendly mode.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173", "--strictPort"]
