# ─── Workspace ────────────────────────────────────────────────────────────────
# Absolute path on the HOST machine where your projects will be stored.
# The directory is created automatically if it does not exist.
# Example: /srv/projects   or   /home/you/projects
WORKSPACE_DIR=/srv/projects

# ─── VS Code Server ───────────────────────────────────────────────────────────
# Port exposed on the host to access VS Code in the browser.
VSCODE_PORT=8443

# Password to access the VS Code web interface.
VSCODE_PASSWORD=changeme

# Timezone for the container (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
VSCODE_TZ=Europe/Paris
