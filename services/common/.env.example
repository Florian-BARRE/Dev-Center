# Common variables used by Docker Compose interpolation.
#
# Copy this file to services/common/.env and customize values.
#
# This file does NOT get injected into containers directly.
# It is only used for docker compose variable substitution.

# REQUIRED: Root directory where runtime data is persisted.
# Linux example:   /opt/dev-center
# macOS example:   /Users/you/dev-center
# Windows example: C:/dev-data/dev-center
DATA_ROOT=/opt/dev-center

# OPTIONAL: Backend host port.
DEV_CENTER_PORT=8000

# OPTIONAL: code-server host port.
CODE_SERVER_PORT=8443

# OPTIONAL (DEV ONLY): Frontend host port for Vite.
FRONTEND_PORT=5173

# OPTIONAL: Host Claude credentials directory.
# If blank, docker-compose.yml falls back to ~/.claude.
CLAUDE_HOST_DIR=

# OPTIONAL: Host Claude global config file.
# If blank, docker-compose.yml falls back to ~/.claude.json.
CLAUDE_JSON_HOST_PATH=

# OPTIONAL: Host SSH key directory.
# If blank, docker-compose.yml falls back to ~/.ssh.
SSH_KEY_PATH=

# OPTIONAL (DEV ONLY): Enable polling file watcher for Docker Desktop edge cases.
# false = lower CPU usage, true = more reliable file watching on some hosts.
CHOKIDAR_USEPOLLING=false
