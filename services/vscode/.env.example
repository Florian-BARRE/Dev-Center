# ─────────────────────────────────────────────────────────────
# VS Code Server (code-server)
# Container: code-server
# ─────────────────────────────────────────────────────────────

# Password for the VS Code web interface.
# Leave blank if access is already restricted by a reverse proxy (e.g. Zoraxy).
#
# Note: docker-compose.yml uses --auth none by default.
# To enable password auth, remove --auth none from the code-server command
# in docker-compose.yml and set a password here.
PASSWORD=
