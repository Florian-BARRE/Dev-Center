# IDH App — Dev Environment Variables
# Copy to dev_data/.env and fill in real values before running:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up

# ───── Required: Logging ─────
# These have no defaults and must always be set.
LOGGING_CONSOLE_LEVEL=DEBUG
LOGGING_FILE_LEVEL=DEBUG
LOGGING_ENABLE_CONSOLE=true
LOGGING_ENABLE_FILE=false
LOGGING_LPP_FORMAT=ShortFormat

# ───── Required: IDH Secrets ─────
# Webhook signature secret — must match the value sent by OpenClaw.
# In dev, any non-empty string works (e.g. "dev-secret").
IDH_WEBHOOK_SECRET=dev-secret-change-me

# ───── OpenClaw Gateway ─────
# Telegram bot token — required by openclaw-gateway to connect to Telegram.
TELEGRAM_BOT_TOKEN=your-bot-token-here

# ───── Optional: FastAPI ─────
# These have sensible defaults; override here if needed.
# FASTAPI_APP_NAME=IDH App (dev)
# FASTAPI_DEBUG_MODE=true         # already set via docker-compose.dev.yml environment block
# CORS_ALLOWED_ORIGINS=*

# ───── Optional: IDH tuning ─────
# BRIDGE_TTL_HOURS=8
# OPENCLAW_GATEWAY_PORT=18789
