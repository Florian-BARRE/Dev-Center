# dev-center-app runtime environment.
#
# Copy this file to services/dev-center-app/.env and edit only if needed.
# All variables below are optional because the app has safe defaults.

# OPTIONAL: FastAPI application name shown in metadata/logs.
FASTAPI_APP_NAME=dev-center-app

# OPTIONAL: Comma-separated origins allowed by CORS.
# Set explicit production domain(s) here when deployed behind a real hostname.
# Example: https://devcenter.example.com
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# OPTIONAL: Default session duration in hours.
DEFAULT_TTL_HOURS=8

# OPTIONAL: Minutes before expiry when auto-renew should trigger.
RENEW_THRESHOLD_MINUTES=30
