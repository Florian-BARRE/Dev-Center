# ─────────────────────────────────────────────────────────────
# IDH Plugin — idh-app FastAPI backend
# Container: idh-app
# ─────────────────────────────────────────────────────────────

# HMAC-SHA256 secret shared between OpenClaw and idh-app.
# Leave blank — setup.sh generates a secure random value on first run.
IDH_WEBHOOK_SECRET=

# How many hours a claude remote-control session stays alive.
BRIDGE_TTL_HOURS=8

# ── FastAPI ─────────────────────────────────────────────────

FASTAPI_APP_NAME=IDH App
FASTAPI_DEBUG_MODE=false
# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=*

# ── Telegram ────────────────────────────────────────────────

# Telegram Bot API token — used by SchedulerService for session transition alerts.
# Leave empty to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=

# ── Logging ─────────────────────────────────────────────────

LOGGING_CONSOLE_LEVEL=INFO
LOGGING_FILE_LEVEL=DEBUG
LOGGING_ENABLE_CONSOLE=true
LOGGING_ENABLE_FILE=false
# Available formats: ShortFormat, DebugFormat
LOGGING_LPP_FORMAT=ShortFormat
