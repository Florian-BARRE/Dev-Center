# ─────────────────────────────────────────────────────────────
# Common — shared variables used by Docker Compose itself
# (volume paths and host port mappings).
#
# This file is loaded with --env-file by Docker Compose and
# setup.sh. It is NOT an env_file for any container — it drives
# compose file interpolation only.
#
# FILL IN: IDH_DATA_ROOT (the only required field)
# ─────────────────────────────────────────────────────────────

# Root directory where ALL runtime data is stored.
# Every service mounts a sub-directory of this path.
#
# Local dev  →  IDH_DATA_ROOT=./dev_data
# Linux srv  →  IDH_DATA_ROOT=/opt/iah
# macOS srv  →  IDH_DATA_ROOT=/Users/you/iah
IDH_DATA_ROOT=

# ── Host port mappings ──────────────────────────────────────
# Change these only if the defaults conflict with other services
# already running on your host.

# OpenClaw API + webhook endpoint
OPENCLAW_GATEWAY_PORT=18789

# OpenClaw web dashboard
OPENCLAW_DASHBOARD_PORT=18790

# IDH App (FastAPI + React)
IDH_APP_PORT=8000

# VS Code in the browser
CODE_SERVER_PORT=8443
