# ─────────────────────────────────────────────────────────────
# Common — shared variables used by Docker Compose itself
# (volume paths and host port mappings).
#
# This file is loaded with --env-file by Docker Compose and
# setup.sh. It is NOT an env_file for any container — it drives
# compose file interpolation only.
#
# FILL IN: IDH_DATA_ROOT (the only required field)
# ─────────────────────────────────────────────────────────────

# Root directory where ALL runtime data is stored.
# Every service mounts a sub-directory of this path.
#
# Local dev  →  IDH_DATA_ROOT=./dev_data
# Linux srv  →  IDH_DATA_ROOT=/opt/iah
# macOS srv  →  IDH_DATA_ROOT=/Users/you/iah
IDH_DATA_ROOT=

# ── SSH key directory ────────────────────────────────────────
# Directory containing your SSH private keys (id_rsa, id_ed25519, …).
# Mounted read-only into idh-app for git clone/push over SSH.
#
# Leave blank to use the default: ~/.ssh
SSH_KEY_PATH=

# ── Host port mappings ──────────────────────────────────────
# Change these only if the defaults conflict with other services
# already running on your host.
# Leave blank to use the default value shown in the comment.

# OpenClaw API + webhook endpoint (default: 18789)
OPENCLAW_GATEWAY_PORT=

# OpenClaw web dashboard (default: 18790)
OPENCLAW_DASHBOARD_PORT=

# IDH App — FastAPI + React dashboard (default: 8000)
IDH_APP_PORT=

# VS Code in the browser (default: 8443)
CODE_SERVER_PORT=

# Vite HMR dev server — only used with ./start.sh --dev (default: 5173)
IDH_FRONTEND_DEV_PORT=
